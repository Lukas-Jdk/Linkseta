generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique @db.Citext
  name         String?
  createdAt    DateTime         @default(now())
  phone        String?
  role         UserRole         @default(USER)
  updatedAt    DateTime         @updatedAt
  avatarUrl    String?
  supabaseId   String?          @unique
  betaAccess   Boolean          @default(false)
  lifetimeFree Boolean          @default(false)
  auditLogs    AuditLog[]       @relation("UserAuditLogs")
  jobListings  JobListing[]
  profile      ProviderProfile?
  services     ServiceListing[]
}

model ProviderProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  companyName           String?
  description           String?
  website               String?
  isApproved            Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  planId                String?
  trialEndsAt           DateTime?
  lifetimeFree          Boolean   @default(false)
  lifetimeFreeGrantedAt DateTime?
  lifetimeFreeGrantedBy String?
  currentPeriodEnd      DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionStatus    String?

  about             String?
  aboutEn           String?
  aboutNo           String?
  experienceYears   Int?
  completedProjects Int?
  workingHours      Json?

  plan Plan? @relation(fields: [planId], references: [id])
  user User  @relation(fields: [userId], references: [id])
}

model ServiceListing {
  id                String          @id @default(cuid())
  userId            String
  title             String
  slug              String          @unique
  description       String
  priceFrom         Int?
  priceTo           Int?
  isActive          Boolean         @default(true)
  highlighted       Boolean         @default(false)
  cityId            String?
  categoryId        String?
  planId            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  imageUrl          String?
  highlights        String[]        @default([])
  imagePath         String?
  deletedAt         DateTime?
  why1              String?
  why2              String?
  why3              String?
  galleryImagePaths String[]        @default([])
  galleryImageUrls  String[]        @default([])
  descriptionEn     String?
  descriptionNo     String?
  highlightsEn      String[]        @default([])
  highlightsNo      String[]        @default([])
  sourceLocale      String          @default("lt")
  titleEn           String?
  titleNo           String?
  responseTime      String?         @default("1h")
  locationCity      String?
  locationPostcode  String?
  locationRegion    String?
  priceDisplayMode  String?         @default("from")
  brandName         String?
  brandLogoUrl      String?
  brandLogoPath     String?
  reviews           ServiceReview[]

  category   Category?          @relation(fields: [categoryId], references: [id])
  city       City?              @relation(fields: [cityId], references: [id])
  plan       Plan?              @relation(fields: [planId], references: [id])
  user       User               @relation(fields: [userId], references: [id])
  priceItems ServicePriceItem[]
  blocks     ServiceBlock[]

  @@index([isActive, deletedAt, createdAt])
  @@index([isActive, deletedAt, highlighted, createdAt])
  @@index([cityId])
  @@index([categoryId])
  @@index([userId])
  @@index([locationPostcode])
  @@index([locationCity])
}

model ServicePriceItem {
  id          String   @id @default(cuid())
  serviceId   String
  label       String
  labelEn     String?
  labelNo     String?
  note        String?
  noteEn      String?
  noteNo      String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  priceText   String?
  priceTextEn String?
  priceTextNo String?

  service ServiceListing @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, sortOrder])
}

model ServiceBlock {
  id        String @id @default(cuid())
  serviceId String

  title       String
  description String?
  iconKey     String  @default("other")
  sortOrder   Int     @default(0)

  titleEn       String?
  titleNo       String?
  descriptionEn String?
  descriptionNo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service ServiceListing      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  images  ServiceBlockImage[]

  @@index([serviceId, sortOrder])
  @@index([iconKey])
}

model ServiceBlockImage {
  id      String @id @default(cuid())
  blockId String

  url  String
  path String

  altText String?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  block ServiceBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, sortOrder])
  @@index([path])
}

model ServiceReview {
  id         String   @id @default(cuid())
  serviceId  String
  rating     Int
  name       String
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  service ServiceListing @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, isApproved, createdAt])
}

model JobListing {
  id             String   @id @default(cuid())
  userId         String
  title          String
  slug           String   @unique
  description    String
  employmentType String?
  salaryFrom     Int?
  salaryTo       Int?
  isActive       Boolean  @default(true)
  remote         Boolean  @default(false)
  cityId         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  city City? @relation(fields: [cityId], references: [id])
  user User  @relation(fields: [userId], references: [id])

  @@index([isActive, cityId])
  @@index([createdAt])
}

model City {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  postcode         String?
  jobs             JobListing[]
  providerRequests ProviderRequest[]
  services         ServiceListing[]
}

model Category {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  type             CategoryType      @default(SERVICE)
  providerRequests ProviderRequest[]
  services         ServiceListing[]
}

model Plan {
  id                  String            @id @default(cuid())
  name                String
  slug                String            @unique
  priceNok            Int
  period              PlanPeriod        @default(MONTHLY)
  maxListings         Int?
  highlight           Boolean           @default(false)
  maxImagesPerListing Int               @default(1)
  maxServiceBlocks    Int               @default(6)
  isTrial             Boolean           @default(false)
  trialDays           Int?
  canAppearOnHomepage Boolean           @default(false)
  canBecomeTop        Boolean           @default(false)
  profiles            ProviderProfile[]
  services            ServiceListing[]
}

model ProviderRequest {
  id         String                @id @default(cuid())
  name       String
  email      String
  phone      String?
  cityId     String?
  categoryId String?
  message    String?
  status     ProviderRequestStatus @default(PENDING)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])
  city     City?     @relation(fields: [cityId], references: [id])
}

model Conversation {
  id            String    @id
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz(6)
  serviceId     String?   @map("service_id")
  createdBy     String    @map("created_by")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversationId, userId])
  @@index([userId], map: "idx_conv_participants_user")
  @@map("conversation_participants")
}

model Message {
  id             String    @id
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversationId], map: "idx_messages_conversation_id")
  @@index([createdAt(sort: Desc)], map: "idx_messages_created_at")
  @@map("messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  action    String
  entity    String
  entityId  String?
  ip        String?
  userAgent String?
  metadata  Json?

  user User? @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
  @@index([entity, entityId])
}

enum UserRole {
  USER
  ADMIN
}

enum CategoryType {
  SERVICE
  JOB
}

enum PlanPeriod {
  MONTHLY
  YEARLY
}

enum ProviderRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
